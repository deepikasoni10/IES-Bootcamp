{
  "$id": "https://india-energy-stack.github.io/schemas/IES_ARR_FiscalYear.schema.json",
  "type": "object",
  "required": ["fiscalYear", "amountBasis", "lineItems"],
  "properties": {
    "fiscalYear": {
      "type": "string",
      "example": "FY 2025-26"
    },
    "yearType": {
      "type": "string",
      "enum": ["BASE_YEAR", "CONTROL_PERIOD", "HISTORICAL"]
    },
    "amountBasis": {
      "type": "string",
      "enum": ["AUDITED", "APPROVED", "PROPOSED", "TRUED_UP", "NOT_FILED"],
      "description": "What the amounts represent: audited actuals, SERC-approved, DISCOM-proposed, trued-up, or not yet filed."
    },
    "lineItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://india-energy-stack.github.io/schemas/IES_ARR_LineItem.schema.json"
      }
    }
  }
}
