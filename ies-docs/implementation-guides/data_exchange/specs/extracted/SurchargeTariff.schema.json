{
  "$id": "https://india-energy-stack.github.io/schemas/SurchargeTariff.schema.json",
  "type": "object",
  "required": [
    "id",
    "recurrence",
    "interval",
    "value"
  ],
  "properties": {
    "id": {
      "type": "string",
      "example": "peak-surcharge"
    },
    "recurrence": {
      "type": "string",
      "description": "ISO 8601 Duration for recurrence (e.g., P1D for daily).",
      "example": "P1D"
    },
    "interval": {
      "type": "object",
      "description": "An interval defined by a Time-of-Day start and a duration.",
      "required": [
        "start",
        "duration"
      ],
      "properties": {
        "start": {
          "type": "string",
          "description": "ISO 8601 Local Time format (T18:00:00Z).",
          "pattern": "^T\\d{2}:\\d{2}:\\d{2}Z?$",
          "example": "T18:00:00Z"
        },
        "duration": {
          "type": "string",
          "pattern": "^(-?)P(?=\\d|T\\d)(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)([DW]))?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+(?:\\.\\d+)?)S)?)?$",
          "description": "duration in ISO 8601 format",
          "example": "PT1H",
          "default": "PT0S"
        }
      }
    },
    "value": {
      "type": "number",
      "description": "The adjustment value (percentage or absolute)."
    },
    "unit": {
      "type": "string",
      "default": "PERCENT",
      "enum": [
        "PERCENT",
        "INR_PER_KWH"
      ]
    }
  }
}