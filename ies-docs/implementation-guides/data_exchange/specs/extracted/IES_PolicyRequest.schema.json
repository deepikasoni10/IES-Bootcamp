{
  "$id": "https://india-energy-stack.github.io/schemas/IES_PolicyRequest.schema.json",
  "description": "A client provided description of an energy policy (e.g., Tariff).\n",
  "type": "object",
  "required": [
    "objectType",
    "policyID",
    "policyType",
    "programID"
  ],
  "properties": {
    "objectType": {
      "type": "string",
      "description": "Types of objects addressable through API.",
      "enum": [
        "POLICY"
      ]
    },
    "@context": {
      "type": "string",
      "example": "https://raw.githubusercontent.com/beckn/DEG/ies-specs/specification/external/schema/ies/core/context.jsonld"
    },
    "programID": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]*$",
      "minLength": 1,
      "maxLength": 128,
      "description": "URL safe VTN assigned object ID.",
      "example": "object-999"
    },
    "policyID": {
      "type": "string",
      "description": "Contextual identifier for the policy.",
      "example": "MUM-RES-T1"
    },
    "policyName": {
      "type": "string",
      "description": "Descriptive name of the policy.",
      "example": "Residential Telescopic Tariff 2024"
    },
    "policyType": {
      "type": "string",
      "enum": [
        "TARIFF",
        "DISPATCH_GUIDE"
      ]
    },
    "samplingInterval": {
      "type": "string",
      "description": "ISO 8601 Recurrence pattern (Cn/Start/Duration).",
      "example": "R/2024-04-10T00:00:00Z/P1M"
    },
    "energySlabs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "start",
          "price"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "slab-1"
          },
          "start": {
            "type": "number",
            "description": "Energy consumption start point (inclusive) in kWh."
          },
          "end": {
            "type": [
              "number",
              "null"
            ],
            "description": "Energy consumption end point (exclusive) in kWh. Null for infinity."
          },
          "price": {
            "type": "number",
            "description": "Base price for energy in this slab."
          }
        }
      }
    },
    "surchargeTariffs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "recurrence",
          "interval",
          "value"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "peak-surcharge"
          },
          "recurrence": {
            "type": "string",
            "description": "ISO 8601 Duration for recurrence (e.g., P1D for daily).",
            "example": "P1D"
          },
          "interval": {
            "type": "object",
            "description": "An interval defined by a Time-of-Day start and a duration.",
            "required": [
              "start",
              "duration"
            ],
            "properties": {
              "start": {
                "type": "string",
                "description": "ISO 8601 Local Time format (T18:00:00Z).",
                "pattern": "^T\\d{2}:\\d{2}:\\d{2}Z?$",
                "example": "T18:00:00Z"
              },
              "duration": {
                "type": "string",
                "pattern": "^(-?)P(?=\\d|T\\d)(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)([DW]))?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+(?:\\.\\d+)?)S)?)?$",
                "description": "duration in ISO 8601 format",
                "example": "PT1H",
                "default": "PT0S"
              }
            }
          },
          "value": {
            "type": "number",
            "description": "The adjustment value (percentage or absolute)."
          },
          "unit": {
            "type": "string",
            "default": "PERCENT",
            "enum": [
              "PERCENT",
              "INR_PER_KWH"
            ]
          }
        }
      }
    },
    "targets": {
      "type": "array",
      "description": "A list of targets.",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "description": "User generated target string.",
        "example": "group-1"
      },
      "nullable": true,
      "default": null
    }
  }
}