{
  "$id": "https://india-energy-stack.github.io/schemas/TOU_Adjustment.schema.json",
  "type": "object",
  "required": [
    "timeSlot",
    "slotType",
    "value"
  ],
  "properties": {
    "timeSlot": {
      "type": "string",
      "description": "Time range in HH:MM:SS-HH:MM:SS format",
      "example": "06:00:00-10:00:00"
    },
    "slotType": {
      "type": "string",
      "enum": [
        "SURCHARGE",
        "DISCOUNT"
      ]
    },
    "value": {
      "type": "number",
      "description": "The adjustment value (percentage or absolute)"
    },
    "unit": {
      "type": "string",
      "description": "Unit of the adjustment value",
      "default": "PERCENT",
      "enum": [
        "PERCENT",
        "INR_PER_KWH"
      ]
    }
  }
}