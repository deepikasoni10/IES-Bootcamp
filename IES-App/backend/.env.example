# Server
PORT=4000
NODE_ENV=development

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173

# ── Beckn ONIX Sandbox ──────────────────────────────────────────────
# Set USE_MOCK_ONIX=true to use built-in mock SERC (no real ONIX needed)
USE_MOCK_ONIX=true

ONIX_GATEWAY_URL=https://gateway.sandbox.ies
BAP_ID=infosys-discom-bap.sandbox.ies
BAP_URI=http://localhost:4000/callback
BPP_ID=mock-serc.sandbox.ies
BPP_URI=https://mock-serc.sandbox.ies
BECKN_DOMAIN=ies:regulatory
BECKN_VERSION=1.0.0

# ── Credential Service ───────────────────────────────────────────────
CREDENTIAL_SERVICE_URL=https://credentials.sandbox.ies
DISCOM_ID=discom-maharashtra-001
DISCOM_DID=did:ies:discom-maharashtra-001

# ── DeDi Directory ───────────────────────────────────────────────────
DEDI_URL=https://dedi.ies.energy

# ── Mock delays (ms) — realistic async simulation ────────────────────
MOCK_DRAFT_DELAY_MS=2500
MOCK_FORMAL_DELAY_MS=3000
